    },
    {
      "page": "/admin/profile",
      "regex": "^/admin/profile(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/profile(?:/)?$"
    },
    {
      "page": "/admin/settings/about",
      "regex": "^/admin/settings/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/settings/about(?:/)?$"
    },
    {
      "page": "/admin/settings/company",
