# --- Frontend env (this folder only) ---
# Next.js loads, in order: `.env`, `.env.local`, `.env.development` / `.env.production` (see Next.js docs).
# `scripts/run-next-port.js` loads `.env` then `.env.local` before `next dev` / `next start`.
# Use ONE place for API rewrite port: set `BACKEND_PORT` here (match `PORT` in `backend/.env`).

# Frontend HTTP port (`npm run dev` / `npm run start`). Default 3001 if unset.
NODE_ENV=production
PORT=3001

# Port where the backend API listens (must match backend `PORT`). Used for `/api` and `/uploads` rewrites.
BACKEND_PORT=5001
# Or set a full internal base URL instead of host+BACKEND_PORT:
# BACKEND_INTERNAL_URL=http://127.0.0.1:5001

NEXT_PUBLIC_API_BASE_URL=https://portalapi.vuleits.com
NEXT_PUBLIC_SITE_URL=https://vuleits.com

# --- Marketing / Ads (all optional, disabled by default) ---
NEXT_PUBLIC_MARKETING_ENABLED=false

# Google (Ads + optional GA4 via gtag)
NEXT_PUBLIC_GOOGLE_ENABLED=false
NEXT_PUBLIC_GTAG_ID=AW-123456789
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# Optional Google Ads conversion labels from Google Ads UI
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=

# Meta (Facebook / Instagram)
NEXT_PUBLIC_META_ENABLED=false
NEXT_PUBLIC_META_PIXEL_ID=123456789012345

# TikTok
NEXT_PUBLIC_TIKTOK_ENABLED=false
NEXT_PUBLIC_TIKTOK_PIXEL_ID=ABCDEF1234567890

# Zalo
NEXT_PUBLIC_ZALO_ENABLED=false
NEXT_PUBLIC_ZALO_PIXEL_ID=YOUR_ZALO_PIXEL_ID
# Optional script URL provided by your Zalo Ads dashboard
NEXT_PUBLIC_ZALO_SCRIPT_URL=
