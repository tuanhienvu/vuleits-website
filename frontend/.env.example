# --- Frontend env (this folder only) ---
# Next.js loads: `.env`, `.env.local`, then `.env.development` / `.env.production`.
# `scripts/run-next-port.js` loads `.env` then `.env.local` before `next dev` / `next start`.

# Frontend port (default 3001)
PORT=3001

# Backend port for API rewrites and automatic API base URL (must match `PORT` in `backend/.env`).
# You can set `BACKEND_PORT` in the **repo root** `.env` instead; `next.config.ts` merges it for rewrites.
BACKEND_PORT=5001

# Optional: full base URL for the backend. If unset, `lib/resolveBackendApiBase.ts` uses:
#   http://127.0.0.1:${BACKEND_PORT}
# NEXT_PUBLIC_API_BASE_URL=
# BACKEND_INTERNAL_URL=http://127.0.0.1:5001

NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Optional: append CSP directives if you enable a script host not in the defaults (e.g. Zalo pixel URL).
# Example: script-src https://s.cdp.zalo.me; connect-src https://*.zalo.me
# NEXT_PUBLIC_CSP_EXTRA=

# --- Marketing / Ads (optional) ---
NEXT_PUBLIC_MARKETING_ENABLED=false
NEXT_PUBLIC_GOOGLE_ENABLED=false
NEXT_PUBLIC_GTAG_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=
NEXT_PUBLIC_META_ENABLED=false
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_ENABLED=false
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_ZALO_ENABLED=false
NEXT_PUBLIC_ZALO_PIXEL_ID=
NEXT_PUBLIC_ZALO_SCRIPT_URL=
