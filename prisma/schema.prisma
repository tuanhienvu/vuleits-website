generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  displayName String? @db.VarChar(150)
  password  String
  roleId    Int
  isActive  Boolean @default(true)
  isProtected Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role      Role    @relation(fields: [roleId], references: [id])
  products  Product[]
  productAnalytics ProductAnalytics[]
  news      News[]
  media     Media[]
  contacts  Contact[]
  createdPrivacyPolicies PrivacyPolicy[] @relation("CreatedPrivacyPolicies")
  createdTermsOfServices TermsOfService[] @relation("CreatedTermsOfServices")
  userPermissions UserPermission[]
}

// Role-Based Access Control
model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique // SuperAdmin, Admin, Editor
  permissions String? // JSON string of permissions
  users       User[]
  rolePermissions RolePermission[]
}

// -------------------- Products (catalog) --------------------
model ProductCategory {
  id          Int       @id @default(autoincrement()) @map("category_id")
  name        String    @map("category_name") @db.VarChar(150)
  slug        String    @unique @db.VarChar(64)
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]

  @@map("product_categories")
}

model Technology {
  id          Int       @id @default(autoincrement()) @map("tech_id")
  techName    String    @unique @map("tech_name") @db.VarChar(120)
  techLogo    String?   @map("tech_logo") @db.VarChar(2000)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    ProductTechnology[]

  @@map("technologies")
}

model ProductTechnology {
  productId    Int
  technologyId Int
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([productId, technologyId])
  @@map("product_technologies")
}

model Product {
  id               Int       @id @default(autoincrement()) @map("product_id")
  productName      String    @map("product_name") @db.VarChar(200)
  slug             String    @unique @db.VarChar(200)
  shortDescription String    @map("short_description") @db.VarChar(500)
  fullDescription  String    @map("full_description") @db.LongText
  imageUrls        Json      @default("[]")
  videoUrls        Json      @default("[]")
  demoLink         String?   @map("demo_link") @db.VarChar(2000)
  landingPageLink  String?   @map("landing_page_link") @db.VarChar(2000)
  embedDemoUrl     String?   @map("embed_demo_url") @db.VarChar(2000)
  categoryId       Int       @map("category_id")
  category         ProductCategory @relation(fields: [categoryId], references: [id])
  viewsCount       Int       @default(0) @map("views_count")
  demoClickCount   Int       @default(0) @map("demo_click_count")
  isFeatured       Boolean   @default(false) @map("is_featured")
  status           String    @default("Active")
  authorId         Int
  author           User      @relation(fields: [authorId], references: [id])
  seoTitle         String?   @db.VarChar(200)
  seoDescription     String?   @db.VarChar(500)
  seoKeywords        String?   @db.VarChar(500)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  technologies     ProductTechnology[]
  analyticsEvents  ProductAnalytics[]

  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model ProductAnalytics {
  id Int @id @default(autoincrement()) @map("analytics_id")
  productId Int @map("product_id")
  userId Int? @map("user_id")
  actionType String @map("action_type") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("timestamp")
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([actionType])
  @@index([createdAt])
  @@map("product_analytics")
}

// News
model News {
  id              Int     @id @default(autoincrement())
  title           String  @db.VarChar(150)
  slug            String  @unique
  description     String  @db.VarChar(300)
  content         String  @db.LongText
  tags            String? // JSON array
  status          String  @default("Active")

  // Used for filtering/search sections (Politics, Economy, Technology, Entertainment...)
  category        String  @db.VarChar(60) @default("General")
  // Thumbnail (stored in Media table)
  imageId         Int?
  image           Media?  @relation(fields: [imageId], references: [id])

  startDate       DateTime?
  endDate         DateTime?
  publishedAt     DateTime?
  authorId        Int
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author          User    @relation(fields: [authorId], references: [id])
}

// Banner/Slider
model BannerSlider {
  id              Int     @id @default(autoincrement())
  title           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           BannerItem[]
}

model BannerItem {
  id              Int     @id @default(autoincrement())
  sliderId        Int
  mediaId         Int
  position        Int
  timing          Int     @default(5) // Duration in seconds
  link            String?
  altText         String?

  slider          BannerSlider @relation(fields: [sliderId], references: [id], onDelete: Cascade)
  media           Media @relation(fields: [mediaId], references: [id])
}

// Media Management
model Media {
  id              Int     @id @default(autoincrement())
  filename        String
  mimeType        String  // jpg, png, webp, mp4, pdf, docx
  size            Int     // bytes
  folder          String  @default("general")
  url             String
  uploadedById    Int
  createdAt       DateTime @default(now())

  uploadedBy      User    @relation(fields: [uploadedById], references: [id])
  bannerItems     BannerItem[]
  aboutSections   AboutSection[]
  news            News[]

  @@unique([filename, folder])
}

// Contact Messages
model Contact {
  id              Int     @id @default(autoincrement())
  name            String
  email           String
  phone           String?
  message         String  @db.LongText
  status          String  @default("New") // New, Replied, Archived
  submittedById    Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  submittedBy     User?   @relation(fields: [submittedById], references: [id])
}

// About Page Sections (removed duplicate - using the one below)

// Site Settings
model SiteSetting {
  id              Int     @id @default(autoincrement())
  key             String  @unique
  value           String  @db.LongText
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Overrides for public/admin UI strings (merged with code defaults on the client).
model UiMessage {
  id          Int      @id @default(autoincrement())
  locale      String   @db.VarChar(20)
  messageKey  String   @map("message_key") @db.VarChar(190)
  value       String   @db.LongText
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([locale, messageKey])
  @@index([locale])
  @@map("ui_messages")
}

model AboutSection {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  order       Int
  imageId     Int?
  type        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  image       Media?   @relation(fields: [imageId], references: [id])
}

model PrivacyPolicy {
  id              Int      @id @default(autoincrement())
  version         String
  content         String
  slug            String   @unique
  metaTitle       String?
  metaDescription String?
  isActive        Boolean  @default(true)
  publishedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     Int?
  createdBy       User?    @relation("CreatedPrivacyPolicies", fields: [createdById], references: [id])
}

model TermsOfService {
  id              Int      @id @default(autoincrement())
  version         String
  content         String
  slug            String   @unique
  metaTitle       String?
  metaDescription String?
  isActive        Boolean  @default(true)
  publishedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     Int?
  createdBy       User?    @relation("CreatedTermsOfServices", fields: [createdById], references: [id])
}

// -------------------- Authorization Models --------------------
// Permissions and assignments for RBAC (Users, Roles, Permissions)
model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
  userPermissions UserPermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int

  role        Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission  Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserPermission {
  id           Int        @id @default(autoincrement())
  userId       Int
  permissionId Int

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission  Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

// -------------------- Home Page Models --------------------
model HomeFeature {
  id          Int      @id @default(autoincrement())
  icon        String   @db.VarChar(50)
  title       String   @db.VarChar(150)
  description String   @db.VarChar(500)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, order])
}

// -------------------- About Page Models --------------------
model AboutStat {
  id        Int      @id @default(autoincrement())
  number    String   @db.VarChar(50)
  label     String   @db.VarChar(150)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
}

model AboutTeamMember {
  id        Int      @id @default(autoincrement())
  emoji     String   @db.VarChar(50)
  name      String   @db.VarChar(150)
  role      String   @db.VarChar(150)
  bio       String   @db.VarChar(500)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
}

// -------------------- Services Page Models --------------------
model ServiceItem {
  id        Int      @id @default(autoincrement())
  icon      String   @db.VarChar(50)
  title     String   @db.VarChar(150)
  description String @db.VarChar(500)
  features  String?  @db.LongText // JSON array of strings
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
}

